import React, { useMemo, useState } from 'react';
import { createRoot } from 'react-dom/client';
import './style.css';

const MENU=[{category:'Frites',items:[['frites','Frites',3.5],['cheesy-onions','Cheesy Onions',6.5],['cheesy-bacon','Cheesy Bacon',7],['speciale','La Spéciale',6.5],['bolognaise-frite','Frites Bolognaise',7.5]]},{category:'Burgers Signature',items:[['diner66','Le Diner 66',13.5],['texas','Le Texas',14.5],['coyote','Le Coyote',13],['bacon-burger','Le Bacon Burger',12.5],['montagnard','Le Montagnard',14],['bicky-burger','Bicky Burger',8.5],['bicky-crispy','Bicky Crispy',9]]},{category:'Snacks',items:[['fricadelle','Fricadelle',3],['fricadelle-speciale','Fricadelle spéciale',4.5],['viandelle','Viandelle',3.8],['poulycroc','Poulycroc',4.2],['lucifer','Lucifer',4.5],['mexicanos','Mexicanos',4],['brochette','Brochette ardennaise',5.5],['cervelas','Cervelas brun',4],['chix','Chix Fingers',5],['mini-loempia','Mini Loempia',3.5],['hamburger','Hamburger',5.5]]},{category:'Boulets',items:[['boulet-roti','Boulet rôti',4.5],['boulet-lapin','Boulet lapin maison',5.5],['boulet-bolognaise','Boulet bolognaise',5.5]]},{category:'Sauces',items:[['mayo','Mayonnaise',1],['ketchup','Ketchup',1],['curry','Ketchup Curry',1],['poivre','Poivre',1.2],['algerienne','Algérienne',1],['brasil','Brasil',1],['samourai','Samouraï',1],['barbecue','Barbecue sucrée',1],['moutarde','Moutarde',1],['triple','Triple Hamburger',1.2],['tartare','Tartare maison',1.2],['andalouse','Andalouse',1],['lapin','Sauce lapin',1.5],['bolognaise','Sauce bolognaise',1.5]]},{category:'Menus',items:[['menu-classic','Menu Classic',9],['menu-gourmand','Menu Gourmand',15],['routier','Routier',11.5]]},{category:'Boissons',items:[['coca','Coca-Cola',2.5],['coca-zero','Coca Zero',2.5],['fanta','Fanta',2.5],['sprite','Sprite',2.5],['ice-tea','Ice Tea',2.5],['eau','Eau',2]]}].map(s=>({...s,items:s.items.map(([id,name,price])=>({id,name,price}))}));
const euro=v=>v.toLocaleString('fr-BE',{style:'currency',currency:'EUR'});
function App(){const [cart,setCart]=useState([]);const [orders,setOrders]=useState(()=>JSON.parse(localStorage.getItem('orders')||'[]'));const [note,setNote]=useState('');const [name,setName]=useState('');const total=useMemo(()=>cart.reduce((s,i)=>s+i.price*i.qty,0),[cart]);const save=o=>{localStorage.setItem('orders',JSON.stringify(o));setOrders(o)};const add=item=>setCart(p=>{let f=p.find(x=>x.id===item.id);return f?p.map(x=>x.id===item.id?{...x,qty:x.qty+1}:x):[...p,{...item,qty:1}]});const qty=(id,d)=>setCart(p=>p.map(x=>x.id===id?{...x,qty:x.qty+d}:x).filter(x=>x.qty>0));const validate=()=>{if(!cart.length)return;let now=new Date();let order={id:Date.now(),number:orders.length+1,customerName:name||'Client',items:cart,note,total,status:'À préparer',date:now.toLocaleDateString('fr-BE'),time:now.toLocaleTimeString('fr-BE',{hour:'2-digit',minute:'2-digit'}),timestamp:now.getTime()};save([order,...orders]);setCart([]);setName('');setNote('')};const changeStatus=id=>save(orders.map(o=>o.id===id?{...o,status:o.status==='À préparer'?'Prêt':'À préparer'}:o));const now=Date.now();const day=new Date().toLocaleDateString('fr-BE');const caDay=orders.filter(o=>o.date===day).reduce((s,o)=>s+o.total,0);const caWeek=orders.filter(o=>now-o.timestamp<6048e5).reduce((s,o)=>s+o.total,0);const caMonth=orders.filter(o=>now-o.timestamp<2592e6).reduce((s,o)=>s+o.total,0);return <div className="app"><header><div><div className="brand">DINER 66</div><h1>Prise de commandes</h1><p>Foodtruck · caisse privée</p></div><div className="stat"><span>🧾</span><b>{orders.length}</b><small>commandes</small></div></header><div className="layout"><main>{MENU.map(sec=><section key={sec.category}><h2>{sec.category}</h2><div className="grid">{sec.items.map(item=><button className="item" key={item.id} onClick={()=>add(item)}><strong>{item.name}</strong><span>{euro(item.price)}</span></button>)}</div></section>)}</main><aside><h2>🛒 Commande</h2><input value={name} onChange={e=>setName(e.target.value)} placeholder="Nom client"/><div className="cart">{cart.length?cart.map(i=><div className="row" key={i.id}><div><b>{i.name}</b><small>{euro(i.price)} / pièce</small></div><button onClick={()=>qty(i.id,-1)}>−</button><b>{i.qty}</b><button onClick={()=>qty(i.id,1)}>+</button></div>):<p className="empty">Aucun article</p>}</div><textarea value={note} onChange={e=>setNote(e.target.value)} placeholder="Note : sans oignons, sauce à part..."/><div className="total"><span>Total</span><b>{euro(total)}</b></div><button className="validate" onClick={validate}>Valider</button><button className="clear" onClick={()=>setCart([])}>Vider</button></aside></div><div className="recap"><div><span>Jour</span><b>{euro(caDay)}</b></div><div><span>Semaine</span><b>{euro(caWeek)}</b></div><div><span>Mois</span><b>{euro(caMonth)}</b></div></div><h2>Commandes / Historique</h2><div className="history">{orders.map(o=><div className="order" key={o.id}><div><b>Commande #{o.number}</b><p>{o.customerName} · {o.date} {o.time}</p>{o.items.map(i=><small key={i.id}>{i.qty} × {i.name}<br/></small>)}{o.note&&<p>Note : {o.note}</p>}</div><div><button onClick={()=>changeStatus(o.id)}>{o.status}</button><strong>{euro(o.total)}</strong></div></div>)}</div></div>}
createRoot(document.getElementById('root')).render(<App/>);
